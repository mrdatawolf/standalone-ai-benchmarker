# ── Google Sheets ─────────────────────────────────────────────────────────────
# The shared leaderboard sheet. Paste the full URL or just the sheet ID.
SHEETS_URL=https://docs.google.com/spreadsheets/d/1lKvDxJ6aZJOhhJysCRVTpIJsobJRy3PZCO52i7S8I50/edit?usp=sharing

# Google OAuth2 credentials (from Google Cloud Console → APIs & Services → Credentials)
# Create a "Desktop app" OAuth client, download the JSON, and copy the values here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Provider ───────────────────────────────────────────────────────────────
# Default provider when running `ai-bench run` with no flags.
# Options: ollama (default), llamacpp, custom
AI_PROVIDER=ollama

# Default model (leave blank to use the provider default)
AI_MODEL=

# Default base URL (leave blank for standard localhost ports)
# AI_BASE_URL=http://localhost:11434

# ── Viewer ────────────────────────────────────────────────────────────────────
# PORT=3751
